#VRML V2.0 utf8
# Representative 3D model for SS-12D00-G3 SPDT mini slide switch (3-pin, 2.54 mm pitch THT).
# Not the manufacturer CAD model — a dimensionally-representative stand-in for clearance/height checks.
# Authored in millimetres; reference from the .kicad_mod with scale (xyz 0.3937 0.3937 0.3937) = 1/2.54,
# because KiCad treats VRML units as 0.1 inch (2.54 mm).
# Origin = center pin (pad 2) at the board top surface. Body extends +Z (up), pins extend -Z (into board).

# --- switch body (black molded housing, ~8.8 x 3.9 x 3.4 mm) ---
Transform {
  translation 0 0 1.7
  children [
    Shape {
      appearance Appearance { material Material { diffuseColor 0.07 0.07 0.07 ambientIntensity 0.2 shininess 0.2 } }
      geometry Box { size 8.8 3.9 3.4 }
    }
  ]
}

# --- slide actuator (light-grey nub on top, ~2.8 x 1.6 x 1.4 mm) ---
Transform {
  translation 0 0 4.1
  children [
    Shape {
      appearance Appearance { material Material { diffuseColor 0.62 0.62 0.62 ambientIntensity 0.3 shininess 0.3 } }
      geometry Box { size 2.8 1.6 1.4 }
    }
  ]
}

# --- 3 leads (tinned, ~0.6 x 0.6 mm, extend 3 mm below board) at x = -2.54, 0, +2.54 ---
Transform {
  translation -2.54 0 -1.5
  children [ Shape { appearance Appearance { material Material { diffuseColor 0.80 0.80 0.83 ambientIntensity 0.4 shininess 0.6 } } geometry Box { size 0.6 0.6 3.0 } } ]
}
Transform {
  translation 0 0 -1.5
  children [ Shape { appearance Appearance { material Material { diffuseColor 0.80 0.80 0.83 ambientIntensity 0.4 shininess 0.6 } } geometry Box { size 0.6 0.6 3.0 } } ]
}
Transform {
  translation 2.54 0 -1.5
  children [ Shape { appearance Appearance { material Material { diffuseColor 0.80 0.80 0.83 ambientIntensity 0.4 shininess 0.6 } } geometry Box { size 0.6 0.6 3.0 } } ]
}
